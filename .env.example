# LLM config (OpenAI-compatible)
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Allow only localhost origins in dev (default value shown)
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$

# Optional: Frontend can use this (Vite) if you want to avoid hard-coding
# VITE_BACKEND_URL=http://localhost:8000
